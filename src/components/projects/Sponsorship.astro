---
import { Image } from 'astro:assets'

import type { iconsType } from 'astro-pure/types'
import { Button, Icon } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'

import type { SponsorshipAction } from '@/data/projects'

interface Props {
  class?: string
  actions: SponsorshipAction[]
}

const { class: className, actions, ...props } = Astro.props
---

<div class={cn('not-prose flex flex-wrap items-center gap-3', className)} {...props}>
  {
    actions.map((action) => (
      <div class='group/sponsor relative'>
        {action.type === 'link' ? (
          <Button
            class='sponsor-action rounded-xl px-3 py-1.5 hover:border-border'
            href={action.href}
            target={action.target ?? '_blank'}
          >
            <Icon class='size-4.5' name={action.icon as iconsType} slot='before' />
            {action.label}
          </Button>
        ) : (
          <>
            <Button
              as='button'
              type='button'
              class='sponsor-action rounded-xl px-3 py-1.5 hover:border-border'
            >
              <Icon class='size-4.5' name={action.icon as iconsType} slot='before' />
              {action.label}
            </Button>
            <div class='sponsor-qr pointer-events-none absolute left-1/2 top-full z-10 mt-2 w-44 -translate-x-1/2 translate-y-1 rounded-xl border bg-card p-2 opacity-0 shadow-sm transition-all duration-300 ease-out group-hover/sponsor:pointer-events-auto group-hover/sponsor:translate-y-0 group-hover/sponsor:opacity-100 group-focus-within/sponsor:pointer-events-auto group-focus-within/sponsor:translate-y-0 group-focus-within/sponsor:opacity-100'>
              <Image
                class='h-auto w-full rounded-lg'
                src={action.qrImage}
                alt={action.qrAlt ?? `${action.label} QR Code`}
                loading='lazy'
              />
            </div>
          </>
        )}
      </div>
    ))
  }
</div>

<style>
  .sponsor-action {
    transition: transform 300ms ease-out;
  }

  .sponsor-action:hover {
    transform: translateY(-1px);
  }
</style>
