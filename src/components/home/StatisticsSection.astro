---
import { Icon } from 'astro-pure/user'

interface Props {
  onlineSince: string
  lastUpdatedText: string
  totalWordsText: string
  totalPosts: number
}

const DAY_MS = 24 * 60 * 60 * 1000

const toStartOfDay = (date: Date) => new Date(date.getFullYear(), date.getMonth(), date.getDate())

const parseLocalDate = (dateValue: string) => {
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateValue)
  if (!match) return null

  const year = Number(match[1])
  const month = Number(match[2])
  const day = Number(match[3])
  const date = new Date(year, month - 1, day)

  if (
    Number.isNaN(date.valueOf()) ||
    date.getFullYear() !== year ||
    date.getMonth() !== month - 1 ||
    date.getDate() !== day
  ) {
    return null
  }

  return date
}

const getDaysOnline = (dateValue: string) => {
  const onlineSinceDate = parseLocalDate(dateValue)
  if (!onlineSinceDate) return 0

  return Math.max(
    0,
    Math.floor((toStartOfDay(new Date()).valueOf() - toStartOfDay(onlineSinceDate).valueOf()) / DAY_MS)
  )
}

const { onlineSince, lastUpdatedText, totalWordsText, totalPosts } = Astro.props
const initialDaysOnline = getDaysOnline(onlineSince)
---

<div class='flex flex-col gap-y-5'>
  <div class='grid grid-cols-1 gap-4 sm:grid-cols-3'>
    <div class='group flex flex-col items-center gap-2 rounded-lg border border-border bg-background p-4 shadow-sm transition-all hover:border-foreground/25 hover:shadow-lg'>
      <Icon name='time' class='size-5 text-muted-foreground transition-colors group-hover:text-primary' />
      <div class='text-center'>
        <div
          class='flex h-8 items-center justify-center text-2xl font-bold text-foreground transition-colors group-hover:text-primary'
          data-days-online
          data-online-since={onlineSince}
        >
          {initialDaysOnline}
        </div>
        <div class='text-sm text-muted-foreground'>Days Online</div>
      </div>
    </div>

    <div class='group flex flex-col items-center gap-2 rounded-lg border border-border bg-background p-4 shadow-sm transition-all hover:border-foreground/25 hover:shadow-lg'>
      <Icon
        name='calendar'
        class='size-5 text-muted-foreground transition-colors group-hover:text-primary'
      />
      <div class='text-center'>
        <div class='flex h-8 items-center justify-center text-sm font-medium text-foreground transition-colors group-hover:text-primary'>
          {lastUpdatedText}
        </div>
        <div class='text-sm text-muted-foreground'>Last Updated</div>
      </div>
    </div>

    <div class='group flex flex-col items-center gap-2 rounded-lg border border-border bg-background p-4 shadow-sm transition-all hover:border-foreground/25 hover:shadow-lg'>
      <Icon
        name='document'
        class='size-5 text-muted-foreground transition-colors group-hover:text-primary'
      />
      <div class='text-center'>
        <div class='flex h-8 items-center justify-center text-2xl font-bold text-foreground transition-colors group-hover:text-primary'>
          {totalWordsText}
        </div>
        <div class='text-sm text-muted-foreground'>Total Words</div>
      </div>
    </div>
  </div>

  <div class='flex items-center justify-between rounded-lg border border-border bg-background px-4 py-3 text-sm shadow-sm'>
    <span class='text-muted-foreground'>Total Posts</span>
    <span class='font-medium text-foreground'>{totalPosts}</span>
  </div>
</div>

<script is:inline>
  const DAY_MS = 24 * 60 * 60 * 1000

  const toStartOfDay = (date) => new Date(date.getFullYear(), date.getMonth(), date.getDate())

  const parseLocalDate = (dateValue) => {
    const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateValue)
    if (!match) return null

    const year = Number(match[1])
    const month = Number(match[2])
    const day = Number(match[3])
    const date = new Date(year, month - 1, day)

    if (
      Number.isNaN(date.valueOf()) ||
      date.getFullYear() !== year ||
      date.getMonth() !== month - 1 ||
      date.getDate() !== day
    ) {
      return null
    }

    return date
  }

  const updateDaysOnline = () => {
    const elements = document.querySelectorAll('[data-days-online]')

    for (const element of elements) {
      if (!(element instanceof HTMLElement)) continue

      const onlineSince = element.dataset.onlineSince
      const onlineSinceDate = onlineSince ? parseLocalDate(onlineSince) : null
      if (!onlineSinceDate) {
        element.textContent = '0'
        continue
      }

      const daysOnline = Math.max(
        0,
        Math.floor((toStartOfDay(new Date()).valueOf() - toStartOfDay(onlineSinceDate).valueOf()) / DAY_MS)
      )
      element.textContent = String(daysOnline)
    }
  }

  updateDaysOnline()
  document.addEventListener('astro:page-load', updateDaysOnline)
</script>
