---
import type { ImageMetadata } from 'astro'
import { render } from 'astro:content'
import { Image } from 'astro:assets'

import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { getFormattedDate } from 'astro-pure/utils'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import ContributionHeatmap from '@/components/home/ContributionHeatmap.astro'
import StatisticsSection from '@/components/home/StatisticsSection.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import { heatmapWindowDays, onlineSince } from '@/data/home-statistics'
import config from '@/site-config'

const MAX_POSTS = 10

const toDateKey = (date: Date) => {
  const year = date.getFullYear()
  const month = String(date.getMonth() + 1).padStart(2, '0')
  const day = String(date.getDate()).padStart(2, '0')
  return `${year}-${month}-${day}`
}

const formatTotalWords = (words: number) => {
  if (words >= 10000) {
    const short = (words / 10000).toFixed(1).replace(/\.0$/, '')
    return `${short}w`
  }
  return words.toLocaleString('en-US')
}

const allPosts = await getBlogCollection()
const posts = allPosts.filter((post) => !post.data.draft)
const allPostsByDate = sortMDByDate([...posts]).slice(0, MAX_POSTS)

const totalPosts = posts.length

const postWordCounts = await Promise.all(
  posts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post)
    const words = Number(remarkPluginFrontmatter.words ?? 0)
    return Number.isFinite(words) ? words : 0
  })
)
const totalWords = postWordCounts.reduce((sum, words) => sum + words, 0)
const totalWordsText = formatTotalWords(totalWords)

const latestDateMs = posts.reduce((latest, post) => {
  const postDate = new Date(post.data.updatedDate ?? post.data.publishDate)
  const value = postDate.valueOf()
  if (Number.isNaN(value)) return latest
  return Math.max(latest, value)
}, -Infinity)

const lastUpdatedText =
  latestDateMs === -Infinity
    ? '--'
    : getFormattedDate(new Date(latestDateMs), { month: 'short', day: 'numeric', year: 'numeric' })

const contributionMap = new Map<string, number>()

for (const post of posts) {
  const uniqueDates = new Set<string>()
  const publishDate = new Date(post.data.publishDate)

  if (!Number.isNaN(publishDate.valueOf())) {
    uniqueDates.add(toDateKey(publishDate))
  }

  if (post.data.updatedDate) {
    const updatedDate = new Date(post.data.updatedDate)
    if (!Number.isNaN(updatedDate.valueOf())) {
      uniqueDates.add(toDateKey(updatedDate))
    }
  }

  for (const date of uniqueDates) {
    contributionMap.set(date, (contributionMap.get(date) ?? 0) + 1)
  }
}

const contributionRecords = [...contributionMap.entries()]
  .sort(([dateA], [dateB]) => dateA.localeCompare(dateB))
  .map(([date, count]) => ({ date, count }))

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='China'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label
            title='Github'
            as='a'
            href='https://github.com/wittzz-crypto'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>

    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground'>学生</p>
        <p class='text-muted-foreground'>
          目前是BUAA计算与智能专业本科生。
        </p>
        <Button title='More about me' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>
      {
        allPostsByDate.length > 0 && (
          <Section title='Posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='More posts' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }

      {
        /* <Section title='Experience'>
      <Card
        heading='Lorem Ipsum'
        subheading='Sit amet consectetur'
        date='Dec 2022 - Nov 2023'
        imagePath='/src/assets/about-astro.png'
        altText='Lorem, ipsum dolor sit'
        imageClass='h-12 w-auto md:-start-16'
      >
        <ul class='ms-4 list-disc text-muted-foreground'>
          <li>
            Lorem, ipsum dolor sit amet consectetur adipisicing elit. Dolore debitis recusandae, ut
            molestiae laboriosam pariatur!

            <li>Lorem ipsum dolor sit amet consectetur adipisicing elit. Molestiae, pariatur!</li>
          </li>
        </ul>
      </Card>
      <Card
        heading='Lorem Ipsum'
        subheading='Sit amet consectetur'
        date='Dec 2022 - Nov 2023'
        imagePath='/src/assets/about-astro.png'
        altText='Lorem, ipsum dolor sit'
        imageClass='h-12 w-auto md:-start-16'
      />
    </Section> */
      }
      <Section title='Education'>
        <Card
          as='a'
          class='!bg-background'
          heading='北京航空航天大学'
          subheading=''
          date='August 2025 - '
          href=''
        >
          {
            /* <ul class='ms-4 list-disc text-muted-foreground'>
          <li>
            Lorem, ipsum dolor sit amet consectetur adipisicing elit. Dolore debitis recusandae, ut
            molestiae laboriosam pariatur!
          </li>
          <li>Lorem ipsum dolor sit amet consectetur adipisicing elit. Molestiae, pariatur!</li>
        </ul> */
          }
        </Card>
      </Section>

      <Section title='Statistics'>
        <StatisticsSection
          onlineSince={onlineSince}
          lastUpdatedText={lastUpdatedText}
          totalWordsText={totalWordsText}
          totalPosts={totalPosts}
        />
      </Section>

      <ContributionHeatmap records={contributionRecords} windowDays={heatmapWindowDays} />
    </div>
  </main>
</PageLayout>
